# Required Worker secrets. Values are intentionally empty; Wrangler uses this
# file only to generate deterministic binding types.
# GitHub App id
GITHUB_APP_ID=
# GitHub App private key (PEM format)
GITHUB_PRIVATE_KEY=
# GitHub OAuth client id
GITHUB_CLIENT_ID=
# GitHub OAuth client secret
GITHUB_CLIENT_SECRET=
# Secret used to verify GitHub webhook signatures
GITHUB_WEBHOOK_SECRET=
# Shared secret for GitHub Actions authentication
API_SECRET=

# Optional Analytics Engine SQL credentials can be set in .dev.vars or .env.
# Cloudflare account id for Analytics Engine SQL
# ANALYTICS_ENGINE_ACCOUNT_ID=
# Token with Account Analytics Read permission
# ANALYTICS_ENGINE_API_TOKEN=
