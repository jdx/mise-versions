# Required Worker secrets. Values are intentionally empty; Wrangler uses this
# file only to generate deterministic binding types.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
API_SECRET=

# Optional Analytics Engine SQL credentials can be set in .dev.vars or .env.
# ANALYTICS_ENGINE_ACCOUNT_ID=
# ANALYTICS_ENGINE_API_TOKEN=
